  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
